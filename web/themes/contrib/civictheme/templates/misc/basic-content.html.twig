{#
/**
 * @file
 * CivicTheme implementation to display Basic content component.
 */
#}
{% set props = {
  theme: component_theme,
  content: content,
  is_contained: is_contained,
  with_background: with_background,
  attributes: attributes,
  modifier_class: modifier_class|default(''),
} %}
{% if vertical_spacing is defined and vertical_spacing is not null %}
  {% set props = props|merge({vertical_spacing: vertical_spacing}) %}
{% endif %}
{% include 'civictheme:basic-content' with props only %}
