{#
/**
 * @file
 * CivicTheme implementation to display a MObile Navigation block.
 */
#}
{% extends 'block.html.twig' %}

{% block content_block %}
  {% include 'civictheme:mobile-navigation-trigger' with {
    theme: trigger_theme|default('light'),
    text: trigger_text,
  } %}

  {% include 'civictheme:mobile-navigation' with {
    theme: theme|default('light'),
    top_menu: top_menu,
    bottom_menu: bottom_menu,
  } %}
{% endblock %}
