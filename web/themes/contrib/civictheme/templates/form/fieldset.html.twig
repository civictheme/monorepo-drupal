{#
/**
 * @file
 * CivicTheme implementation to display a fieldset.
 */
#}

{% include 'civictheme:fieldset' with {
  theme: theme|default('light'),
  legend: legend.title|default(''),
  description: description|default(''),
  description_display: description_display|default('before'),
  message: errors|default(''),
  message_type: message_type|default('error'),
  fields: children,
  is_required: is_required|default(required|default(false)),
  prefix: prefix|default(''),
  suffix: suffix|default(''),
  attributes: attributes,
  modifier_class: modifier_class|default(''),
} only %}
